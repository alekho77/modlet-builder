<modlet>
  <!--
    Alloy Motor Tool Parts - progression unlock.
    Source: EV_AlloyMotorToolParts by Aleksei Khozin
  -->
  <fragment target="progression">
    <set xpath="/progression/crafting_skills/crafting_skill[@name='craftingSalvageTools']/@max_level">100</set>
    <append xpath="/progression/crafting_skills/crafting_skill[@name='craftingSalvageTools']/effect_group">
      <passive_effect name="RecipeTagUnlocked" operation="base_set" level="76,100" value="1" tags="toolPartsA_unlock"/>
    </append>
    <set xpath="/progression/crafting_skills/crafting_skill[@name='craftingSalvageTools']/display_entry[last()]/@unlock_level">51,55,60,65,70,75,76</set>
    <append xpath="/progression/crafting_skills/crafting_skill[@name='craftingSalvageTools']/display_entry[last()]">
      <unlock_entry item="motorToolPartsA_Alloy" unlock_tier="1"/>
    </append>
  </fragment>
</modlet>
