<modlet>
  <!--
    EV_LootBox — drink loot groups by quality tier.
    Source: EV_LootBox by Aleksei Khozin
  -->
  <fragment name="ev.lootbox.loot.drink-groups" target="loot">
    <append xpath="/lootcontainers">
      <lootgroup name="evLootBoxDrinkSimple" count="1">
        <item name="drinkJarYuccaJuice"   count="1,3"/>
        <item name="drinkJarBoiledWater"  count="5,7"/>
      </lootgroup>
      <lootgroup name="evLootBoxDrinkGood" count="1">
        <item name="drinkJarPureMineralWater" count="2,4"/>
        <item name="drinkJarRedTea"           count="2,3"/>
      </lootgroup>
      <lootgroup name="evLootBoxDrinkValuable" count="1">
        <item name="drinkJarHoneyTea"         count="2,4"/>
        <item name="drinkJarBlackStrapCoffee" count="1,3"/>
      </lootgroup>
    </append>
  </fragment>
</modlet>
