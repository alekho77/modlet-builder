<modlet>
  <!--
    The 'hint' attribute was used in an earlier design for multi-mod routing
    but is no longer supported. Use separate output directories instead.
    Expected warning: Unknown attribute 'hint' on an unnamed fragment.
  -->
  <fragment target="items" hint="SomeMod">
    <append xpath="/items">
      <item name="testItem"/>
    </append>
  </fragment>
</modlet>
